<?xml version="1.0" encoding="utf-8"?>
<!--
    Active-call screen for the native voice/video-call stack.

    Layout strategy:
      - The root is a FrameLayout. For voice calls it carries the
        opaque @drawable/bg_incoming_call background; for video calls
        ActiveCallActivity.applyKindVisibility() clears the root's
        background to null so the underlay SurfaceView (the remote
        renderer) shows through.
      - active_call_remote_video fills the whole screen behind
        everything; visible only on video calls. SurfaceView lives
        in the underlay window — the root's transparent background
        on video calls lets the system hole-punch through and
        composite the surface beneath the activity UI.
      - active_call_local_video is a small picture-in-picture in the
        upper-right corner; visible only on video calls.
        setZOrderMediaOverlay(true) at runtime puts it above the
        remote underlay but below the regular UI.
      - The voice-style overlay (avatar + name + status + controls)
        sits on top, with the avatar hidden on video calls. Two
        gradient scrims (top/bottom) provide control legibility when
        the underlay shows bright camera frames.
      - Two new bottom-row buttons (camera-off, flip-camera) are
        gated VISIBLE only on video calls.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/active_call_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_incoming_call">

    <!-- Full-screen remote video (gone for voice calls).
         No XML background: an opaque background here would defeat the
         SurfaceView hole-punch. Once the first frame renders the
         renderer covers itself; before that the activity background
         (transparent on video) shows through. -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/active_call_remote_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Picture-in-picture self-view (gone for voice calls). -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/active_call_local_video"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="20dp"
        android:visibility="gone" />

    <!-- Top scrim for status text legibility on video calls. Hidden on
         voice calls so the existing background-only chrome is unchanged. -->
    <View
        android:id="@+id/active_call_top_scrim"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_active_call_scrim_top"
        android:visibility="gone" />

    <!-- Bottom scrim for controls legibility on video calls. -->
    <View
        android:id="@+id/active_call_bottom_scrim"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_active_call_scrim_bottom"
        android:visibility="gone" />

    <!-- Existing voice-call layout: avatar + name + status + controls. -->
    <LinearLayout
        android:id="@+id/active_call_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/active_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting…"
            android:textColor="@color/incoming_call_text"
            android:textSize="16sp"
            android:alpha="0.85"
            android:layout_marginBottom="24dp" />

        <ImageView
            android:id="@+id/active_call_avatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="Peer avatar"
            android:src="@drawable/ic_call_avatar_placeholder"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/active_call_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/incoming_call_text"
            android:textSize="28sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="" />

        <TextView
            android:id="@+id/active_call_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/incoming_call_text"
            android:textSize="18sp"
            android:alpha="0.85"
            android:text="" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="48dp">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/active_call_mute"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_active_call_button_secondary"
                    android:src="@drawable/ic_mic"
                    android:scaleType="center"
                    android:contentDescription="Toggle microphone mute"
                    android:tint="@color/incoming_call_text" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/active_call_camera_off"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_active_call_button_secondary"
                    android:src="@drawable/ic_video"
                    android:scaleType="center"
                    android:visibility="gone"
                    android:contentDescription="Toggle camera"
                    android:tint="@color/incoming_call_text" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/active_call_hangup"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_call_button_decline"
                    android:src="@drawable/ic_call_end"
                    android:scaleType="center"
                    android:contentDescription="Hang up"
                    android:tint="@color/incoming_call_text" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/active_call_camera_flip"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_active_call_button_secondary"
                    android:src="@drawable/ic_camera_flip"
                    android:scaleType="center"
                    android:visibility="gone"
                    android:contentDescription="Flip camera"
                    android:tint="@color/incoming_call_text" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/active_call_speaker"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_active_call_button_secondary"
                    android:src="@drawable/ic_speaker"
                    android:scaleType="center"
                    android:contentDescription="Toggle speakerphone"
                    android:tint="@color/incoming_call_text" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
