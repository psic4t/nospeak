<?xml version="1.0" encoding="utf-8"?>
<!--
    Bottom-sheet-style background for the video-call control row.
    Matches the app's modal / sheet pattern: rounded top corners,
    flat bottom edge flush with the screen, near-opaque dark fill
    with a subtle translucent-white top stroke. Elevation is set on
    the view itself for a natural drop shadow above the bar.

    Fill uses the app dark palette (#101820) at ~94 % opacity —
    opaque enough for legibility but slightly translucent so the
    remote video is faintly visible, approximating the frosted-glass
    backdrop-blur-xl the web side uses on its bottom sheets.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#F0182030" />
    <corners
        android:topLeftRadius="24dp"
        android:topRightRadius="24dp"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp" />
    <stroke
        android:width="1dp"
        android:color="#1AFFFFFF"
        android:dashWidth="0dp"
        android:dashGap="0dp" />
</shape>